# AI Provider Configuration
# Use Groq for free cloud AI (recommended)
GROQ_API_KEY=your_groq_api_key_here

# Groq Model Selection:
# ⚡ llama-3.1-8b-instant (FASTEST 1-2s - RECOMMENDED for production)
# 🚀 mixtral-8x7b-32768 (FAST 2-5s - good balance)
# 🧠 llama-3.1-70b-versatile (SLOW 10-20s - complex tasks only)
# ⚠️ llama-3.3-70b-versatile (VERY SLOW 20-40s - will cause timeouts!)
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (optional, paid)
OPENAI_API_KEY=your_openai_key_here

# Ollama (local development)
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Database
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Vector Database
VECTOR_DB=chroma
PINECONE_API_KEY=your_pinecone_key

# Authentication
SECRET_KEY=your-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Firebase Google sign-in (same project ID as NEXT_PUBLIC_FIREBASE_PROJECT_ID in .env.local)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Frontend URLs (for CORS) — main app on 3000; extra Next dev on 3001 if needed
FRONTEND_URL=http://localhost:3000
# Also allowed in app.py: http://localhost:3001
