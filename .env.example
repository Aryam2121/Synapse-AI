# =============================================================================
# Synapse AI — local development env setup
# =============================================================================
#
# Terminal 1 (project root):  npm run dev     → Frontend http://localhost:3000
# Terminal 2 (project root):  npm run backend → API       http://localhost:8000
# If port 8000 is busy:         npm run backend:stop  then  npm run backend
#
# Copy this file to .env.local (frontend) and backend/.env (API).
# =============================================================================

# --- Frontend (.env.local at project root) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase (Google sign-in) — from Firebase Console → Project settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Backend (backend/.env) ---
# FRONTEND_URL=http://localhost:3000
# PORT=8000
# DATABASE_URL=sqlite+aiosqlite:///./app.db
# SECRET_KEY=your-secret-key-min-32-chars
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
# GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Optional
# REDIS_URL=redis://localhost:6379
# PINECONE_API_KEY=your_pinecone_api_key

